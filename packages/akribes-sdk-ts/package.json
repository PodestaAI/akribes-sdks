{
  "name": "akribes",
  "version": "0.23.0",
  "description": "TypeScript / Bun client for the Akribes workflow server. Browser-safe ESM.",
  "license": "MIT",
  "homepage": "https://akribes.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PodestaAI/akribes-sdks.git",
    "directory": "packages/akribes-sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/PodestaAI/akribes-sdks/issues"
  },
  "keywords": [
    "akribes",
    "llm",
    "ai-workflows",
    "agent",
    "dsl",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "bun run example_client.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
